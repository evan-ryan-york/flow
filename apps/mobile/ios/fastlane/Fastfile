# Fastfile for Flow iOS deployment
# https://docs.fastlane.tools

default_platform(:ios)

platform :ios do

  desc "Build and upload to TestFlight"
  lane :beta do
    # Install CocoaPods dependencies (Podfile is at ios/App/Podfile)
    cocoapods(
      podfile: "App/Podfile",
      use_bundle_exec: false
    )

    # Increment build number (handled by deploy.sh, but can also be done here)
    # increment_build_number(xcodeproj: "App/App.xcodeproj")

    # Build the app for App Store distribution
    build_app(
      workspace: "App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "FlowApp.ipa",
      clean: true,
      xcargs: "-allowProvisioningUpdates"
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )

    # Clean up build artifacts
    clean_build_artifacts
  end

  desc "Build and upload to App Store Connect for production release"
  lane :release do
    # Install CocoaPods dependencies
    cocoapods(
      podfile: "App/Podfile",
      use_bundle_exec: false
    )

    # Build the app for App Store distribution
    build_app(
      workspace: "App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "FlowApp.ipa",
      clean: true,
      xcargs: "-allowProvisioningUpdates"
    )

    # Upload to App Store Connect
    # Uses upload_to_testflight because the binary is identical —
    # select the build in App Store Connect for production release
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )

    # Clean up build artifacts
    clean_build_artifacts
  end

  desc "Build only (no upload)"
  lane :build_only do
    cocoapods(
      podfile: "App/Podfile",
      use_bundle_exec: false
    )

    build_app(
      workspace: "App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "FlowApp.ipa",
      clean: true,
      xcargs: "-allowProvisioningUpdates"
    )
  end

  desc "Increment build number"
  lane :bump_build do
    increment_build_number(xcodeproj: "App/App.xcodeproj")
  end

  desc "Register new devices"
  lane :register_devices do
    register_devices(devices_file: "./devices.txt")
    match(type: "development", force_for_new_devices: true)
  end

end

# Error handling
error do |lane, exception|
  puts "Error in lane #{lane}: #{exception.message}"
end
