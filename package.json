{
  "name": "flow-app",
  "version": "1.0.17",
  "description": "",
  "main": "index.js",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "cd apps/web && pnpm run dev",
    "dev:mobile": "cd apps/mobile && pnpm run dev",
    "dev:desktop": "cd apps/desktop && pnpm run dev",
    "build": "pnpm run typecheck && pnpm run lint && echo '✅ All TypeScript and linting checks passed'",
    "build:turbo": "turbo run build",
    "build:web": "cd apps/web && pnpm run build",
    "build:web:export": "cd apps/web && NEXT_OUTPUT=export pnpm run build",
    "build:mobile": "cd apps/mobile && pnpm run build",
    "build:desktop": "cd apps/desktop && pnpm run build",
    "build:desktop:full": "pnpm build:web:export && pnpm build:desktop",
    "mobile:ios": "cd apps/mobile && pnpm run ios",
    "mobile:android": "cd apps/mobile && pnpm run android",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "db:execute": "supabase db execute",
    "deploy:all": "./deploy.sh --all --patch --skip-checks"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "supabase": "^2.47.2",
    "turbo": "^2.5.6",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "react": "19.1.0"
  }
}
